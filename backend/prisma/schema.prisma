// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  EDITOR
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  COMPLETED
  CANCELLED
}

model Profile {
  id        String   @id  // = auth.users.id
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  email     String?  // ✅ nullable болго
  @@map("profiles")
}


model Category {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())

  @@index([slug])
  @@map("categories")
}

model Product {
  id          String           @id @default(uuid())
  title       String
  slug        String           @unique
  description String?
  basePrice   Decimal          @default(0) // Base price (variants can override)
  categoryId  String
  category    Category         @relation(fields: [categoryId], references: [id])
  variants    ProductVariant[] // Product variants
  rating      Float            @default(0)
  reviews     Int              @default(0)
  features    String[]         @default([])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([slug])
  @@index([createdAt])
  @@map("products")
}

model ProductVariant {
  id            String   @id @default(uuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name          String   // Variant name (e.g., "Black/Red", "Ocean Blue")
  sku           String   @unique // Unique SKU for this variant
  price         Decimal  // Variant-specific price
  originalPrice Decimal? // Original price if on sale
  sizes         String[] @default([]) // Available sizes for this variant
  imagePath     String   // Main thumbnail image
  galleryPaths  String[] @default([]) // Additional gallery images
  stock         Int      @default(0) // Variant stock
  isAvailable   Boolean  @default(true) // Availability flag
  sortOrder     Int      @default(0) // Display order
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productId])
  @@index([sku])
  @@map("product_variants")
}

model Order {
  id        String      @id @default(uuid())
  total     Decimal
  status    OrderStatus @default(PENDING)
  items     Json        // Order items (snapshot)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("orders")
}
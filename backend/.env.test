# Test Environment - SEPARATE DATABASE!
NODE_ENV=test
PORT=3001

# TEST DATABASE - DO NOT USE PRODUCTION!
# Option 1: Use Supabase test project
DATABASE_URL="postgresql://postgres.TEST_PROJECT_ID:TEST_PASSWORD@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.TEST_PROJECT_ID:TEST_PASSWORD@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres"

# Option 2: Use local PostgreSQL
# DATABASE_URL="postgresql://postgres:password@localhost:5432/ecommerce_test"
# DIRECT_URL="postgresql://postgres:password@localhost:5432/ecommerce_test"

# Security
CORS_ORIGIN="http://localhost:5176"

# Rate Limiting (relaxed for tests)
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW=1 minute

# Supabase (use test project)
SUPABASE_URL="https://TEST_PROJECT_ID.supabase.co"
SUPABASE_JWT_SECRET="TEST_JWT_SECRET"
SUPABASE_ANON_KEY="TEST_ANON_KEY"

# R2 Storage (mock or test bucket)
R2_ACCOUNT_ID=test
R2_ACCESS_KEY_ID=test
R2_SECRET_ACCESS_KEY=test
R2_BUCKET_NAME=test-products
R2_PUBLIC_DOMAIN=test.r2.dev

# QPay - MOCK MODE for tests
QPAY_BASE_URL=https://merchant-sandbox.qpay.mn
QPAY_USERNAME=TEST_MERCHANT
QPAY_PASSWORD=123456
QPAY_INVOICE_CODE=TEST_INVOICE
QPAY_CALLBACK_URL=http://localhost:3001/api/payment/callback
QPAY_MOCK_MODE=true

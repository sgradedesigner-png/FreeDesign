# ===================================
# Backend Environment Variables
# ===================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git!

# Node Environment
NODE_ENV=development
PORT=3000

# Database URLs (Supabase)
# Get these from: https://app.supabase.com/project/_/settings/database
DATABASE_URL="postgresql://postgres.PROJECT_ID:PASSWORD@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=20&pool_timeout=10&connect_timeout=5"
DIRECT_URL="postgresql://postgres.PROJECT_ID:PASSWORD@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres"

# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
SUPABASE_JWT_SECRET="your-jwt-secret-here"
SUPABASE_ANON_KEY="sb_publishable_YOUR_ANON_KEY_HERE"

# CORS Settings (comma-separated origins)
CORS_ORIGIN="http://localhost:5176,https://ecommerce-final-project.pages.dev,https://korean-goods.com,https://www.korean-goods.com"

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# CSRF Protection
# Generate a random secret for cookie signing (use: openssl rand -hex 32)
COOKIE_SECRET=change-this-to-a-random-32-char-string-in-production

# Cloudflare R2 Storage (for product images)
# Get these from: Cloudflare Dashboard > R2 > Manage API Tokens
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=products
R2_PUBLIC_DOMAIN=your-bucket.r2.dev

# QPay Payment Gateway Configuration
# Sandbox (for testing):
QPAY_BASE_URL=https://merchant-sandbox.qpay.mn
QPAY_USERNAME=TEST_MERCHANT
QPAY_PASSWORD=your-qpay-password
QPAY_INVOICE_CODE=TEST_INVOICE
QPAY_CALLBACK_URL=https://your-ngrok-or-public-url.com/api/payment/callback

# QPay Mock Mode (set to 'true' to bypass real QPay API for local testing)
QPAY_MOCK_MODE=false

# QPay Request Settings (optional)
QPAY_REQUEST_TIMEOUT_MS=45000
QPAY_INVOICE_MAX_RETRIES=3

# Production QPay (uncomment and configure when deploying):
# QPAY_BASE_URL=https://merchant.qpay.mn
# QPAY_USERNAME=your_production_username
# QPAY_PASSWORD=your_production_password
# QPAY_INVOICE_CODE=your_production_invoice_code
# QPAY_CALLBACK_URL=https://yourdomain.com/api/payment/callback

# Security (optional, for local development with self-signed certificates)
# NODE_TLS_REJECT_UNAUTHORIZED=0

# Email Service (Resend)
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=support@korean-goods.com
EMAIL_FROM_NAME=Korean Goods Support

# Cron Jobs
# Run cron jobs immediately on startup (useful for testing in development)
CRON_RUN_ON_STARTUP=false
# Maximum emails to send per cron run (prevents email bombing)
CRON_MAX_EMAILS_PER_RUN=50

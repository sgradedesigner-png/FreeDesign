# Production Environment Configuration
# ⚠️ IMPORTANT: Never commit this file with actual production values!
# This is a template - replace all values with your actual production credentials

# Supabase Configuration (Production)
VITE_SUPABASE_URL=https://YOUR_PRODUCTION_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_production_anon_key_here

# Backend API Configuration (Production)
VITE_API_URL=https://api.yourdomain.com

# Cloudflare Turnstile (Production Site Key)
VITE_TURNSTILE_SITE_KEY=your_production_turnstile_site_key

# Environment
VITE_ENV=production

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_TRACKING=true
VITE_ENABLE_DEBUG_MODE=false

# Security
VITE_API_TIMEOUT=30000
VITE_MAX_FILE_SIZE=5242880

# Build Information (Auto-populated by CI/CD)
# VITE_BUILD_VERSION=
# VITE_BUILD_DATE=
# VITE_COMMIT_SHA=

# ===================================
# Sentry Error Tracking (Production)
# ===================================
# Sentry is AUTO-ENABLED in production (no need to set VITE_SENTRY_ENABLED=true)
VITE_SENTRY_DSN=https://698e3734afe9640749a140348d1e45a2@o4510859559305216.ingest.de.sentry.io/4510859561730128
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=admin@1.0.0

# Source Maps Upload (Build-time only)

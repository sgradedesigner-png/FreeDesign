# Environment Configuration Example
# Copy this file to .env (development), .env.staging, or .env.production
# and fill in your actual values

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Backend API Configuration
VITE_API_URL=http://localhost:4000

# Cloudflare Turnstile Site Key
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key

# Environment (development, staging, production)
VITE_ENV=development

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_TRACKING=false
VITE_ENABLE_DEBUG_MODE=true

# Phase 0 Feature Flags (Admin)
VITE_FF_DTF_ADMIN_V1=false  # DTF-specific admin features

# Security Settings
VITE_API_TIMEOUT=30000
VITE_MAX_FILE_SIZE=5242880

# ===================================
# Sentry Error Tracking Configuration
# ===================================
# Get these from: https://sentry.io/settings/
# Sentry is DISABLED by default in development, ENABLED in production
# Set VITE_SENTRY_ENABLED=true to force-enable in development

# Sentry DSN (required) - Get from Sentry project settings
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Enable/disable Sentry (optional - auto-enabled in production)
VITE_SENTRY_ENABLED=false

# Sentry environment (optional - defaults to VITE_ENV or 'development')
VITE_SENTRY_ENVIRONMENT=development

# Sentry release version (optional - used for tracking which version caused errors)
# Format: appname@version (e.g., admin@1.2.3)
VITE_SENTRY_RELEASE=admin@0.0.1

# ===================================
# Sentry Source Maps Upload (Build-time only)
# ===================================
# Required for production builds to upload source maps
# Get auth token from: https://sentry.io/settings/account/api/auth-tokens/

# Sentry organization slug (e.g., your-company)
VITE_SENTRY_ORG=your-org-slug

# Sentry project slug (e.g., admin-panel)
VITE_SENTRY_PROJECT=your-project-slug

# Sentry auth token (KEEP SECRET! Add to .env.local, NOT .env)
VITE_SENTRY_AUTH_TOKEN=your_auth_token_here




# =============================================================================
# Store App - PRODUCTION Environment
# =============================================================================
# DO NOT commit this file with real credentials!
# Add actual values in your hosting platform's environment variables
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-production-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_production_anon_key

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
VITE_API_URL=https://api.yourdomain.com

# -----------------------------------------------------------------------------
# Cloudflare R2 Storage
# -----------------------------------------------------------------------------
VITE_R2_PUBLIC_BASE_URL=https://your-production-bucket.r2.dev

# -----------------------------------------------------------------------------
# Cloudflare Turnstile CAPTCHA
# -----------------------------------------------------------------------------
VITE_TURNSTILE_SITE_KEY=your_production_turnstile_key

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
VITE_ENV=production

# -----------------------------------------------------------------------------
# Feature Flags (Production)
# -----------------------------------------------------------------------------
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_TRACKING=true
VITE_ENABLE_DEBUG_MODE=false

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
VITE_API_TIMEOUT=30000
VITE_MAX_FILE_SIZE=5242880

# -----------------------------------------------------------------------------
# Sentry Error Tracking (PRODUCTION)
# -----------------------------------------------------------------------------
VITE_SENTRY_DSN=https://bb05d26dfa09c3887a1e0943cae8168d@o4510859559305216.ingest.de.sentry.io/4510859872239696
# VITE_SENTRY_ENABLED is auto-enabled in production (no need to set)
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=store@1.0.0

# -----------------------------------------------------------------------------
# Sentry Source Maps (Optional - for readable stack traces)
# -----------------------------------------------------------------------------
# VITE_SENTRY_ORG=your-org-slug
# VITE_SENTRY_PROJECT=your-project-slug
# VITE_SENTRY_AUTH_TOKEN=sntrys_xxxxx  # Add in CI/CD secrets only!

# =============================================================================
# DEPLOYMENT CHECKLIST:
# =============================================================================
# [ ] Update VITE_SUPABASE_URL with production Supabase project
# [ ] Update VITE_SUPABASE_ANON_KEY with production key
# [ ] Update VITE_API_URL with production API domain
# [ ] Update VITE_R2_PUBLIC_BASE_URL with production R2 bucket
# [ ] Update VITE_TURNSTILE_SITE_KEY with production Cloudflare key
# [ ] Set VITE_SENTRY_RELEASE to match git tag or version (e.g., store@1.0.0)
# [ ] Verify VITE_ENABLE_DEBUG_MODE=false
# [ ] Test Sentry error tracking works
# [ ] Verify console.log statements are removed in production build
# =============================================================================

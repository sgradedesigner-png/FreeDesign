# =============================================================================
# Store App - STAGING Environment
# =============================================================================
# Used for pre-production testing
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-staging-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_staging_anon_key

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
VITE_API_URL=https://api-staging.yourdomain.com

# -----------------------------------------------------------------------------
# Cloudflare R2 Storage
# -----------------------------------------------------------------------------
VITE_R2_PUBLIC_BASE_URL=https://your-staging-bucket.r2.dev

# -----------------------------------------------------------------------------
# Cloudflare Turnstile CAPTCHA
# -----------------------------------------------------------------------------
VITE_TURNSTILE_SITE_KEY=your_staging_turnstile_key

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
VITE_ENV=staging

# -----------------------------------------------------------------------------
# Feature Flags (Staging - similar to production)
# -----------------------------------------------------------------------------
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_TRACKING=true
VITE_ENABLE_DEBUG_MODE=false

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
VITE_API_TIMEOUT=30000
VITE_MAX_FILE_SIZE=5242880

# -----------------------------------------------------------------------------
# Sentry Error Tracking (STAGING)
# -----------------------------------------------------------------------------
VITE_SENTRY_DSN=https://bb05d26dfa09c3887a1e0943cae8168d@o4510859559305216.ingest.de.sentry.io/4510859872239696
VITE_SENTRY_ENABLED=true
VITE_SENTRY_ENVIRONMENT=staging
VITE_SENTRY_RELEASE=store@1.0.0-staging

# =============================================================================
# STAGING NOTES:
# =============================================================================
# - Staging should mirror production as closely as possible
# - Use separate Supabase project for staging data isolation
# - Test all features before promoting to production
# - Monitor Sentry for staging-specific issues
# =============================================================================

# =============================================================================
# Store App Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env files to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Get these from: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# -----------------------------------------------------------------------------
# Backend API Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Development: http://localhost:3000
# Production: https://your-api-domain.com
VITE_API_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Cloudflare R2 Storage (REQUIRED)
# -----------------------------------------------------------------------------
# Public URL for accessing uploaded images
# Example: https://pub-xxxxx.r2.dev
VITE_R2_PUBLIC_BASE_URL=https://your-r2-bucket.r2.dev

# -----------------------------------------------------------------------------
# Cloudflare Turnstile CAPTCHA (REQUIRED)
# -----------------------------------------------------------------------------
# Get site key from: https://dash.cloudflare.com/
# Used for login/signup bot protection
VITE_TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Environment Configuration
# -----------------------------------------------------------------------------
# Options: development, staging, production
VITE_ENV=development

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable/disable features for testing
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_TRACKING=true
VITE_ENABLE_DEBUG_MODE=true

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# Request timeout in milliseconds (30 seconds)
VITE_API_TIMEOUT=30000

# Maximum file upload size in bytes (5MB)
VITE_MAX_FILE_SIZE=5242880

# -----------------------------------------------------------------------------
# Sentry Error Tracking (OPTIONAL but RECOMMENDED for production)
# -----------------------------------------------------------------------------
# Get DSN from: https://sentry.io/settings/projects/
# Leave empty to disable Sentry
VITE_SENTRY_DSN=https://bb05d26dfa09c3887a1e0943cae8168d@o4510859559305216.ingest.de.sentry.io/4510859872239696

# Enable Sentry in development (default: false, auto-enabled in production)
VITE_SENTRY_ENABLED=false

# Sentry environment tag (development, staging, production)
VITE_SENTRY_ENVIRONMENT=development

# Sentry release version (used for tracking deployments)
VITE_SENTRY_RELEASE=store@0.0.1

# -----------------------------------------------------------------------------
# Sentry Source Maps Upload (OPTIONAL - for production builds)
# -----------------------------------------------------------------------------
# Only needed if you want readable stack traces in Sentry
# Generate auth token: https://sentry.io/settings/account/api/auth-tokens/
# Required scopes: project:releases, org:read

# Your Sentry organization slug
# VITE_SENTRY_ORG=your-org-slug

# Your Sentry project slug
# VITE_SENTRY_PROJECT=your-project-slug

# Sentry auth token (DO NOT COMMIT - add to .env.local only!)
# VITE_SENTRY_AUTH_TOKEN=sntrys_your_auth_token_here

# =============================================================================
# NOTES:
# =============================================================================
# 1. Create .env.local for local development (not tracked by git)
# 2. Use .env.production for production deployment
# 3. Use .env.staging for staging environment
# 4. Never commit actual credentials to version control
# 5. Update VITE_SENTRY_RELEASE on each deployment for better tracking
# =============================================================================
